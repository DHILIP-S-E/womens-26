    # Database
DATABASE_URL=postgresql://user:password@localhost:5432/health_tracking_db

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Server
PORT=3000
NODE_ENV=development

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SNS_PHONE_NUMBER=+1234567890

# AWS HealthLake
HEALTHLAKE_DATASTORE_ENDPOINT=https://healthlake.us-east-1.amazonaws.com/datastore/YOUR_DATASTORE_ID/r4/

# AWS Lambda ARNs (set after deploying Lambda functions)
LAMBDA_REMINDER_PROCESSOR_ARN=arn:aws:lambda:us-east-1:123456789012:function:reminder-processor
LAMBDA_PERIOD_ALERT_ARN=arn:aws:lambda:us-east-1:123456789012:function:period-alert

# AWS EventBridge
EVENTBRIDGE_BUS_NAME=default

# OpenAI/Gemini
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Frontend
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
